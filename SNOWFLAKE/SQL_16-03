--1. Convert date from MM-DD-YYYY to DD-MON-YYYY format.
SELECT TO_CHAR(CREATED_DATE,'DD-MON-YYYY'),
FROM DIM_CUSTOMER;

--2. Find top 3 customers per city based on total order amount.
SELECT C.CUSTOMER_NAME, SUM(O.AMOUNT) AS TOTAL_AMOUNT, C.CITY
FROM DIM_CUSTOMER C 
JOIN FACT_ORDERS O 
ON C.CUSTOMER_ID=O.CUSTOMER_ID
GROUP BY C.CITY,C.CUSTOMER_NAME
QUALIFY ROW_NUMBER() OVER(PARTITION BY C.CITY ORDER BY SUM(O.AMOUNT) DESC)<=3;

SELECT *
FROM(
    SELECT C.CITY,C.CUSTOMER_NAME,SUM(F.AMOUNT) AS TOTAL_REVENUE,
    ROW_NUMBER() OVER (PARTITION BY C.CITY ORDER BY SUM(F.AMOUNT) DESC) AS RN
    FROM DIM_CUSTOMER C
    JOIN FACT_ORDERS F
    ON C.CUSTOMER_ID = F.CUSTOMER_ID
    GROUP BY C.CITY, C.CUSTOMER_NAME
) T
WHERE RN <= 3
ORDER BY CITY, TOTAL_REVENUE DESC;

--3. Retrieve latest order placed by each customer
SELECT CUSTOMER_ID, ORDER_ID, ORDER_DATE
FROM FACT_ORDERS
QUALIFY ROW_NUMBER() OVER(PARTITION BY ORDER_ID ORDER BY ORDER_DATE DESC)=1;

--4. Identify customers who never placed any orders
SELECT C.CUSTOMER_ID,C.CUSTOMER_NAME,O.CUSTOMER_ID
FROM DIM_CUSTOMER C
LEFT JOIN FACT_ORDERS O
ON C.CUSTOMER_ID= O.CUSTOMER_ID
WHERE O.CUSTOMER_ID IS NULL;

--5. Calculate monthly revenue from FACT_ORDERS.Calculate total revenue per month.
SELECT MONTH(ORDER_DATE) AS ORDER_MONTH, SUM(AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS
GROUP BY MONTH(ORDER_DATE)
ORDER BY;
--METHOD 2
SELECT DATE_TRUNC(MONTH,ORDER_DATE) AS ORDER_MONTH, SUM(AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS
GROUP BY ORDER_MONTH;

--6. Compute running total of order amount per customer ordered by date
SELECT CUSTOMER_ID, ORDER_DATE, AMOUNT,
SUM(AMOUNT) OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE) AS RUNNING_TOTAL
FROM FACT_ORDERS
ORDER BY CUSTOMER_ID
;

--7. Detect duplicate ORDER_ID values in FACT_ORDERS
SELECT * FROM (SELECT ORDER_ID,
ROW_NUMBER() OVER (PARTITION BY ORDER_ID ORDER BY ORDER_ID) AS RN
FROM FACT_ORDERS) AS T
WHERE RN>1;
--MEHTOD 2
SELECT * FROM (SELECT ORDER_ID,
FROM FACT_ORDERS) AS T
QUALIFY ROW_NUMBER() OVER (PARTITION BY ORDER_ID ORDER BY ORDER_ID)>1;

--8. Demonstrate difference between UNION and UNION ALL using order datasets.
--UNION
SELECT CUSTOMER_ID FROM DIM_CUSTOMER
UNION
SELECT CUSTOMER_ID FROM FACT_ORDERS
ORDER BY CUSTOMER_ID;
--UNION ALL
SELECT CUSTOMER_ID FROM DIM_CUSTOMER
UNION ALL
SELECT CUSTOMER_ID FROM FACT_ORDERS
ORDER BY CUSTOMER_ID;

--9. Find previous order amount per customer using LAG.
SELECT CUSTOMER_ID, ORDER_DATE, AMOUNT,
LAG(AMOUNT) OVER(PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC) AS PREVIOUS_AMOUNT
FROM FACT_ORDERS;

--10. Find next order amount per customer using LEAD
SELECT CUSTOMER_ID, ORDER_DATE, AMOUNT, 
LEAD(AMOUNT) OVER(PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE) AS NEXT_AMOUNT
FROM FACT_ORDERS;

--11. Identify orders where amount is greater than the customer's average order amount
SELECT ORDER_ID, CUSTOMER_ID, AMOUNT,
AVG(AMOUNT) OVER (PARTITION BY CUSTOMER_ID) AS AVG_CUSTOMER_AMOUNT
FROM FACT_ORDERS
QUALIFY AMOUNT > AVG(AMOUNT) OVER(PARTITION BY CUSTOMER_ID);

--12. Find the highest order amount per city.
SELECT C.CUSTOMER_ID, C.CITY, O.AMOUNT,
ROW_NUMBER() OVER (PARTITION BY CITY ORDER BY O.AMOUNT DESC) AS RN
FROM DIM_CUSTOMER C 
JOIN FACT_ORDERS O
ON C.CUSTOMER_ID=O.CUSTOMER_ID
QUALIFY RN=1;

--13. Calculate number of days between consecutive orders for each customer.
SELECT CUSTOMER_ID,ORDER_DATE,
LAG(ORDER_DATE) OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE) AS PREVIOUS_ORDER_DATE,
DATEDIFF(DAY, LAG(ORDER_DATE) OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE), ORDER_DATE) AS DAYS_BETWEEN_ORDERS
FROM FACT_ORDERS;

--14.Count number of orders by STATUS
SELECT STATUS, 
COUNT(STATUS) AS TOTAL_ORDERS
FROM FACT_ORDERS
GROUP BY STATUS;

--15. Categorize customers into Platinum, Gold, Silver based on revenue.
SELECT CUSTOMER_ID, SUM(AMOUNT) AS TOTAL_REVENUE,
CASE
     WHEN SUM(AMOUNT)>=1500 THEN 'PLATINUM'
     WHEN SUM(AMOUNT)>=700 THEN 'GOLD'
     ELSE 'SILVER'
END AS CUSTOMER_CATEGORY
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID;

--16.Retrieve first and last order date per customer.
SELECT CUSTOMER_ID,
MAX(ORDER_DATE) AS LAST_ORDER,
MIN(ORDER_DATE) AS FIRST_ORDER
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID;

--17.Find highest order placed each day.
SELECT ORDER_DATE, MAX(AMOUNT)
FROM FACT_ORDERS
GROUP BY ORDER_DATE;
 

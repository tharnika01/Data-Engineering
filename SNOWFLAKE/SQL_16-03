SELECT CUSTOMER_ID, COUNT(ORDER_ID) AS TOTAL_ORDERS
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
HAVING COUNT(ORDER_ID)>5;

--19. Retrieve orders placed in the last 7 days.
SELECT * FROM FACT_ORDERS
WHERE DATEDIFF(DAY,ORDER_DATE,CURRENT_DATE)<=7;

--20. From multiple records per ORDER_ID, return the latest status using CDC logic.
SELECT * FROM (
    SELECT ORDER_ID, STATUS,
    ROW_NUMBER() OVER(PARTITION BY ORDER_ID ORDER BY UPDATED_TS DESC) AS RN
    FROM FACT_ORDERS
    ) AS T
    WHERE RN=1;
    

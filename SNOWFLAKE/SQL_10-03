USE DATABASE ASSIGNMENTS;

USE SCHEMA SQLASSIGNMENTS;

SELECT * FROM DIM_CUSTOMER;

SELECT * FROM FACT_ORDERS;

--Retrieve the list of all customers from DIM_CUSTOMER showing CUSTOMER_ID, CUSTOMER_NAME,CITY.Sort the result by CUSTOMER_NAME in ascending order.
SELECT CUSTOMER_ID, CUSTOMER_NAME, CITY AS ORDER_PER_CUSSTOMER
FROM DIM_CUSTOMER
ORDER BY CUSTOMER_NAME ASC;

-- Find all active customers from DIM_CUSTOMER.Sort the results by CITY.
SELECT CUSTOMER_ID, CUSTOMER_NAME, CITY, CUSTOMER_TYPE
FROM DIM_CUSTOMER
ORDER BY CITY ASC;

--From FACT_ORDERS, display all orders where:AMOUNT is greater than 500.Sort the results by AMOUNT descending.
SELECT ORDER_ID, CUSTOMER_ID, ORDER_DATE, AMOUNT
FROM FACT_ORDERS
ORDER BY AMOUNT DESC;

--Find the total number of orders per customer.Sort the result by TOTAL_ORDERS descending.
SELECT CUSTOMER_ID, COUNT(ORDER_ID) AS TOTAL_ORDERS
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
ORDER BY COUNT(ORDER_ID) DESC;

--Find the total revenue generated per customer using FACT_ORDERS.Only show customers whose revenue is greater than 2000.
SELECT CUSTOMER_ID, SUM(AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
HAVING SUM(AMOUNT)>2000;

--Only include active customers.Sort results by ORDER_DATE descending.
SELECT C.CUSTOMER_NAME, C.CITY, O.ORDER_ID, O.AMOUNT, O.ORDER_DATE
FROM DIM_CUSTOMER C
JOIN FACT_ORDERS O 
ON C.CUSTOMER_ID=O.CUSTOMER_ID
ORDER BY ORDER_DATE DESC;

--Calculate total revenue generated by each city.Only include cities where total revenue is greater than 5000.Sort results by TOTAL_REVENUE descending.
SELECT C.CITY, SUM(AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS O
JOIN DIM_CUSTOMER C
ON O.CUSTOMER_ID=C.CUSTOMER_ID
GROUP BY CITY
HAVING SUM(AMOUNT)>2000
ORDER BY TOTAL_REVENUE DESC;

/*Classify each order amount using CASE.

Classification rules:

AMOUNT	CATEGORY
> 1000	HIGH_VALUE
500–1000	MEDIUM_VALUE
< 500	LOW_VALUE

Sort the results by AMOUNT descending.*/
SELECT ORDER_ID, CUSTOMER_ID, AMOUNT, 
CASE
    WHEN AMOUNT > 1000 THEN 'HIGH_VALUE'
    WHEN AMOUNT BETWEEN 500 AND 1000 THEN 'MEDIUM_VALUE'
    ELSE 'LOW_VALUE'
END AS ORDER_CATEGORY
FROM FACT_ORDERS
ORDER BY AMOUNT DESC;

--Find the total number of orders placed by each city.Only include cities where total orders are greater than 3.Sort the result by TOTAL_ORDERS descending.
SELECT C.CITY, COUNT(O.ORDER_ID) AS TOTAL_ORDERS
FROM FACT_ORDERS O
JOIN DIM_CUSTOMER C
ON O.CUSTOMER_ID=C.CUSTOMER_ID
GROUP BY CITY
HAVING TOTAL_ORDERS>3
ORDER BY TOTAL_ORDERS DESC
LIMIT 3;

--Find customers who have placed more than 2 orders.Sort the results by TOTAL_REVENUE descending.
SELECT CUSTOMER_ID, COUNT(ORDER_ID) AS TOTAL_ORDERS, SUM(AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS
GROUP BY CUSTOMER_ID
HAVING TOTAL_ORDERS>2
ORDER BY TOTAL_REVENUE DESC;

-- Find the latest order placed by each customer.Use ROW_NUMBER() to ensure only the latest order is returned.
SELECT * FROM (SELECT CUSTOMER_ID, ORDER_ID, ORDER_DATE, AMOUNT,
ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC) AS RN
FROM FACT_ORDERS) AS T
WHERE RN=1
;
--METHOD 2
SELECT CUSTOMER_ID, ORDER_ID, ORDER_DATE, AMOUNT,
FROM FACT_ORDERS
QUALIFY ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC)=1;

--Find the top 3 highest spending customers in each city.Use ROW_NUMBER() partitioned by city.
SELECT C.CITY, C.CUSTOMER_ID, SUM(O.AMOUNT) AS TOTAL_REVENUE
FROM FACT_ORDERS O
JOIN DIM_CUSTOMER C
ON O.CUSTOMER_ID=C.CUSTOMER_ID
GROUP BY C.CITY,C.CUSTOMER_ID
QUALIFY ROW_NUMBER() OVER (PARTITION BY CITY ORDER BY SUM(O.AMOUNT) DESC)<=3;
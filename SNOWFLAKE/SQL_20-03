/*Create a stored procedure that:
What to Implement
•	Use MERGE
•	Update columns: CUSTOMER_NAME, CITY
•	No history tracking
*/
CREATE OR REPLACE PROCEDURE LOAD_DATA()
RETURNS STRING
LANGUAGE SQL
AS
$$
BEGIN
MERGE INTO DIM_CUSTOMER DC
USING STG_CUSTOMER SC
ON DC.CUSTOMER_ID = SC.CUSTOMER_ID

WHEN MATCHED
AND (DC.CUSTOMER_NAME<>SC.CUSTOMER_NAME OR DC.CITY<>SC.CITY)
THEN UPDATE SET
        DC.CUSTOMER_NAME= SC.CUSTOMER_NAME,
        DC.CITY= SC.CITY

WHEN NOT MATCHED THEN
INSERT (CUSTOMER_ID,CUSTOMER_NAME,CITY)
VALUES (SC.CUSTOMER_ID, SC.CUSTOMER_NAME, SC.CITY);

RETURN 'SCD TYPE 1 LOAD COMPLETED';

END;
$$;
CALL LOAD_DATA();

/*Create a stored procedure that:
•	Tracks history of changes
•	When a record changes:
o	Expire old record (END_DATE)
o	Insert new record with updated data
*/
CREATE OR REPLACE PROCEDURE SCD2()
RETURNS  STRING
LANGUAGE SQL
AS
$$
BEGIN
MERGE INTO DIM_CUSTOMER DC
USING STG_CUSTOMER SC 
ON DC.CUSTOMER_ID = SC.CUSTOMER_ID AND DC.IS_ACTIVE=TRUE

WHEN MATCHED AND (DC.CUSTOMER_ID<>SC.CUSTOMER_ID OR DC.CITY<>SC.CITY) 
THEN UPDATE SET 
        END_DATE=CURRENT_DATE - 1,
        IS_ACTIVE=FALSE

WHEN NOT MATCHED THEN
INSERT (CUSTOMER_ID,
        CUSTOMER_NAME,
        CITY,
        START_DATE,
        END_DATE,
        IS_ACTIVE
        )
VALUES(SC.CUSTOMER_ID,
        SC.CUSTOMER_NAME,
        SC.CITY,
        CURRENT_DATE,
        NULL,
        TRUE
        );
RETURN 'SCD TYPE 2 LOAD COMPLETED';
END;
$$;
CALL SCD2();
/*Create a stored procedure that:
•	Stores only previous value
•	Updates current value
*/
CREATE OR REPLACE PROCEDURE SCD3()
RETURNS STRING 
LANGUAGE SQL
AS
$$
BEGIN

MERGE INTO DIM_CUSTOMER DC
USING STG_CUSTOMER SC 
ON DC.CUSTOMER_ID = SC.CUSTOMER_ID

WHEN MATCHED AND (DC.CITY <> SC.CITY OR DC.CUSTOMER_NAME<>SC.CUSTOMER_NAME)
THEN UPDATE SET 
            PREVIOUS_CITY=DC.CITY,
            CITY=SC.CITY,
            CUSTOMER_NAME=SC.CUSTOMER_NAME

WHEN NOT MATCHED THEN 
INSERT (CUSTOMER_ID, CUSTOMER_NAME, CITY, PREVIOUS_CITY)
VALUES(SC.CUSTOMER_ID, SC.CUSTOMER_NAME, SC.CITY,NULL);

RETURN 'SCD TYPE 3 COMPLETED';
END;
$$;

CALL SCD3();
--STAGING TABLE
CREATE OR REPLACE TABLE STG_CUSTOMER (
    CUSTOMER_ID INT,
    CUSTOMER_NAME STRING,
    CITY STRING,
    LOAD_DATE DATE
);

--DIMENSION TABLE
CREATE OR REPLACE TABLE DIM_CUSTOMER (
    CUSTOMER_ID INT,
    CUSTOMER_NAME STRING,
    CITY STRING,
    START_DATE DATE,
    END_DATE DATE,
    IS_ACTIVE BOOLEAN,
    PREVIOUS_CITY STRING,
    CUSTOMER_TYPE STRING,
    CREATED_TS TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UPDATED_TS TIMESTAMP
);

-- FACT TABLE
CREATE OR REPLACE TABLE FACT_ORDERS (
    ORDER_ID INT,
    CUSTOMER_ID INT,
    ORDER_DATE DATE,
    AMOUNT NUMBER(10,2)
);


--2A
ALTER TABLE DIM_CUSTOMER
ADD COLUMN UPDATE_DATE TIMESTAMP;

MERGE INTO DIM_CUSTOMER DC
USING (
    WITH CUSTOMER_REVENUE AS (
    SELECT CUSTOMER_ID,SUM(AMOUNT) AS TOTAL_REVENUE
    FROM FACT_ORDERS
    GROUP BY CUSTOMER_ID
    ),
    CUSTOMER_CATEGORY AS (
    SELECT CUSTOMER_ID,
    TOTAL_REVENUE,
    CASE
        WHEN TOTAL_REVENUE > 50000 THEN 'PLATINUM'
        WHEN TOTAL_REVENUE BETWEEN 20000 AND 50000 THEN 'GOLD'
        ELSE 'SILVER'
        END AS CUSTOMER_TYPE
    FROM CUSTOMER_REVENUE
    )
    SELECT * FROM CUSTOMER_CATEGORY
    ) CC
    ON DC.CUSTOMER_ID = CC.CUSTOMER_ID

    WHEN MATCHED THEN 
    UPDATE SET
    DC.CUSTOMER_TYPE=CC.CUSTOMER_TYPE,
    DC.UPDATE_DATE= CURRENT_TIMESTAMP()

    WHEN NOT MATCHED THEN
    INSERT (CUSTOMER_ID, CUSTOMER_TYPE, UPDATE_DATE)
    VALUES (CC.CUSTOMER_ID, CC.CUSTOMER_TYPE, CURRENT_TIMESTAMP()
    );
SELECT * FROM DIM_CUSTOMER;

-- 2b
WITH CUSTOMER_REVENUE AS  (
    SELECT C.CUSTOMER_ID, C.CUSTOMER_NAME, C.CITY, SUM(O.AMOUNT) AS       TOTAL_REVENUE
    FROM DIM_CUSTOMER C
    JOIN FACT_ORDERS O
    ON C.CUSTOMER_ID = O.CUSTOMER_ID
    GROUP BY C.CUSTOMER_ID, C.CUSTOMER_NAME, C.CITY
),
LATEST_ORDER AS (
    SELECT CUSTOMER_ID, AMOUNT AS LATEST_ORDER_AMOUNT,
    ROW_NUMBER() OVER 
    (PARTITION BY CUSTOMER_ID ORDER BY ORDER_DATE DESC) AS RN 
    FROM FACT_ORDERS
),
CUSTOMER_REPORT AS (
    SELECT CR.CUSTOMER_ID, CR.CITY,CR.TOTAL_REVENUE,
    CASE
        WHEN CR.TOTAL_REVENUE >= 10000 THEN 'HIGH'
        WHEN CR.TOTAL_REVENUE >= 5000 THEN 'MEDIUM'
        ELSE 'LOW'
    END AS REVENUE_CATEGORY,
    
    LO.LATEST_ORDER_AMOUNT,

    RANK() OVER( PARTITION BY CR.CITY ORDER BY CR.TOTAL_REVENUE DESC) AS CUSTOMER_RANK
FROM CUSTOMER_REVENUE CR
JOIN LATEST_ORDER LO 
ON CR.CUSTOMER_ID=LO.CUSTOMER_ID
WHERE LO.RN=1
)
SELECT * FROM CUSTOMER_REPORT;


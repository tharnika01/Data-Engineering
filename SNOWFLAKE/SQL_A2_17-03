--PROCEDURE
CREATE OR REPLACE PROCEDURE USP_PROCESS_DAILY_ORDERS()
RETURNS STRING
LANGUAGE SQL
AS
$$
DECLARE 
    V_TOTAL_COUNT INT;
    V_INVALID_COUNT INT;
    V_VALID_COUNT INT;
    V_INSERT_COUNT INT DEFAULT 0;
    V_UPDATE_COUNT INT DEFAULT 0;

BEGIN

-- 1 Total staging count
SELECT COUNT(*) INTO :V_TOTAL_COUNT
FROM STG_ORDERS;

-- 2️ Insert invalid records
INSERT INTO ORDER_ERROR_LOG (ORDER_ID, ERROR_REASON)
SELECT 
    S.ORDER_ID,
    CASE 
        WHEN S.AMOUNT <= 0 THEN 'INVALID AMOUNT'
        WHEN S.ORDER_DATE > CURRENT_DATE THEN 'INVALID ORDER DATE'
        WHEN C.CUSTOMER_ID IS NULL THEN 'CUSTOMER NOT FOUND'
    END
FROM STG_ORDERS S
LEFT JOIN DIM_CUSTOMER C
    ON S.CUSTOMER_ID = C.CUSTOMER_ID
WHERE S.AMOUNT <= 0
   OR S.ORDER_DATE > CURRENT_DATE
   OR C.CUSTOMER_ID IS NULL;

-- Capture invalid count
SELECT COUNT(*) INTO :V_INVALID_COUNT
FROM ORDER_ERROR_LOG
WHERE LOAD_DATE = CURRENT_DATE;  

-- 3️ Valid + Latest records (CTE)
WITH VALID_DATA AS (
    SELECT S.*
    FROM STG_ORDERS S
    LEFT JOIN DIM_CUSTOMER C
        ON S.CUSTOMER_ID = C.CUSTOMER_ID
    WHERE S.AMOUNT > 0
      AND S.ORDER_DATE <= CURRENT_DATE
      AND C.CUSTOMER_ID IS NOT NULL
),
LATEST_RECORDS AS (
    SELECT *,
        ROW_NUMBER() OVER(
            PARTITION BY ORDER_ID
            ORDER BY ORDER_DATE DESC
        ) AS RN
    FROM VALID_DATA
)

-- 4️ MERGE into FACT_ORDERS
MERGE INTO FACT_ORDERS F
USING (
    SELECT * FROM LATEST_RECORDS WHERE RN = 1
) L
ON F.ORDER_ID = L.ORDER_ID

WHEN MATCHED THEN 
UPDATE SET 
    F.AMOUNT = L.AMOUNT,
    F.ORDER_DATE = L.ORDER_DATE

WHEN NOT MATCHED THEN
INSERT (ORDER_ID, CUSTOMER_ID, ORDER_DATE, AMOUNT)
VALUES (L.ORDER_ID, L.CUSTOMER_ID, L.ORDER_DATE, L.AMOUNT);

-- 5️ Capture valid count
SELECT COUNT(*) INTO :V_VALID_COUNT
FROM STG_ORDERS S
LEFT JOIN DIM_CUSTOMER C
ON S.CUSTOMER_ID = C.CUSTOMER_ID
WHERE S.AMOUNT > 0
  AND S.ORDER_DATE <= CURRENT_DATE
  AND C.CUSTOMER_ID IS NOT NULL;

-- 6️ Insert metrics
INSERT INTO ORDER_PROCESS_METRICS
(TOTAL_COUNT, VALID_COUNT, INVALID_COUNT, INSERT_COUNT, UPDATE_COUNT, PROCESS_DATE)
VALUES 
(:V_TOTAL_COUNT, :V_VALID_COUNT, :V_INVALID_COUNT, :V_INSERT_COUNT, :V_UPDATE_COUNT, CURRENT_TIMESTAMP);

-- 7️ Return success message
RETURN 'PROCESS COMPLETED SUCCESSFULLY';

EXCEPTION
WHEN OTHER THEN
    ROLLBACK;
    RETURN 'PROCESS FAILED';

END;
$$;
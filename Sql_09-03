SELECT * FROM STG_ORDERS;

--join customer and fact table with case
SELECT C.CUSTOMER_NAME, C.CITY, SUM(O.AMOUNT) AS TOTAL_REVENUE, COUNT(O.ORDER_ID) AS TOTAL_ORDERS,

CASE
    WHEN SUM(O.AMOUNT)>2000 THEN 'PLATINUM'
    WHEN SUM(O.AMOUNT)>1000 THEN 'GOLD'
    ELSE 'SILVER'
END AS CATEGORY
    
FROM DIM_CUSTOMER AS C
JOIN FACT_ORDERS AS O ON C.CUSTOMER_ID=O.CUSTOMER_ID
GROUP BY C.CUSTOMER_NAME, C.CITY;

--Top 3 customers per city using row_number 
SELECT * FROM
(SELECT C.CUSTOMER_NAME, C.CITY, SUM(O.AMOUNT) AS TOTAL_AMOUNT,
ROW_NUMBER() OVER (PARTITION BY CITY ORDER BY SUM(AMOUNT) DESC) AS RN
FROM DIM_CUSTOMER AS C
JOIN FACT_ORDERS AS O ON C.CUSTOMER_ID=O.CUSTOMER_ID
GROUP BY CUSTOMER_NAME, CITY) AS T
WHERE RN<=3;

--Create a view
CREATE VIEW  VW_ACTIVE_CUSTOMER_REVENUE AS
SELECT C.CUSTOMER_NAME, C.IS_ACTIVE, COUNT(O.ORDER_ID) AS ORDERS, SUM(O.AMOUNT) AS REVENUE,
CASE 
    WHEN  SUM(O.AMOUNT)>2000 THEN 'PLATINUM'
    WHEN SUM(O.AMOUNT)>1000 THEN 'GOLD'
    ELSE 'SILVER'
END AS CATEGORY

FROM DIM_CUSTOMER AS C
JOIN FACT_ORDERS AS O
ON C.CUSTOMER_ID=O.CUSTOMER_ID
WHERE C.IS_ACTIVE = TRUE
GROUP BY C.CUSTOMER_NAME, C.CITY, C.IS_ACTIVE
HAVING SUM(O.AMOUNT) > 5000 AND COUNT(O.ORDER_ID) >2
;

-- merge + daily incremental load
MERGE INTO FACT_ORDERS F
USING STG_ORDERS S
ON F.ORDER_ID = S.ORDER_ID

WHEN MATCHED THEN
UPDATE SET
    F.CUSTOMER_ID = S.CUSTOMER_ID,
    F.ORDER_DATE = S.ORDER_DATE,
    F.AMOUNT = S.AMOUNT,
    F.STATUS = S.STATUS

WHEN NOT MATCHED THEN
INSERT (
    ORDER_ID,
    CUSTOMER_ID,
    ORDER_DATE,
    AMOUNT,
    STATUS)
VALUES (
    S.ORDER_ID,
    S.CUSTOMER_ID,
    S.ORDER_DATE,
    S.AMOUNT,
    S.STATUS
);


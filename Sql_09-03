CREATE DATABASE ASSIGNMENTS;

USE DATABASE ASSIGNMENTS;

CREATE SCHEMA SQLASSIGNMENTS;
USE SCHEMA SQLASSIGNMENTS;

CREATE TABLE DIM_CUSTOMER(
CUSTOMER_ID INT,
CUSTOMER_NAME STRING,
CITY STRING,
CRESTED_DATE DATE,
IS_ACTIVE BOOLEAN,
CUSTOMER_TYPE STRING
);

CREATE TABLE FACT_ORDERS(
ORDER_ID INT,
CUSTOMER_ID INT,
ORDER_DATE DATE,
AMOUNT NUMBER(10,2),
STATUS STRING,
CREATED_TS TIMESTAMP,
UPDATE_TS TIMESTAMP
);

CREATE TABLE STG_ORDERS(
ORDER_ID INT,
CUSTOMER_ID INT,
ORDER_DATE DATE,
AMOUNT NUMBER(10,2),
STATUS STRING,
CRESTED_TS TIMESTAMP,
UPDATED_TS TIMESTAMP
);

